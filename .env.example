OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
USE_LLM=true
# Keep true for offline demos. Set false to use OPENAI_API_KEY for context-grounded RAG answers.
OFFLINE_MODE=true
APP_URL=http://127.0.0.1:8001

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=muunganohub

# Use sqlite for simple local/public demos, or mysql when your MySQL service is configured.
AUTH_BACKEND=sqlite

# Enables registration and forgot-password emails.
SEND_AUTH_EMAILS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender_email@gmail.com
SMTP_EMAIL=your_sender_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_sender_email@gmail.com
SMTP_FROM_NAME=MuunganoHub

WHATSAPP_VERIFY_TOKEN=choose_a_private_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_cloud_api_access_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_GRAPH_VERSION=v20.0
